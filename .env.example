# Database
DATABASE_URL="postgresql://user:password@localhost:5432/agentlab"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Encryption key for API keys (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-key-here"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="AgentLab <noreply@example.com>"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AgentLab"

# LangGraph Python backend URL (used server-side by Next.js)
# Em produção: use a URL interna do serviço backend no seu ambiente
BACKEND_INTERNAL_URL="http://localhost:8000"

# Inter-service auth secret (generate with: openssl rand -hex 32)
INTERNAL_SECRET="your-internal-secret-here"

# Langfuse observability
# Self-hosted: http://localhost:3010 (use docker-compose.langfuse.yml)
# Cloud: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST="https://cloud.langfuse.com"

# URL pública do dashboard Langfuse para embed no LabPanel (opcional)
NEXT_PUBLIC_LANGFUSE_DASHBOARD_URL=""

# SearXNG — instância self-hosted para o tool web_search
SEARXNG_URL=""
